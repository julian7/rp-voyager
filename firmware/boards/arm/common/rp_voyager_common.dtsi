#include <dt-bindings/zmk/matrix_transform.h>

/ {
	chosen {
		zephyr,code-partition = &code_partition;
		zephyr,console = &uart0;
		zephyr,flash = &flash0;
		zephyr,sram = &sram0;
		zmk,kscan = &kscan0;
		zmk,matrix_transform = &default_transform;
		zmk,underglow = &led_strip;
		zmk,wired_split = &wired_split;
	};

	default_transform: keymap_transform_0 {
		compatible = "zmk,matrix-transform";
		columns = <6>;
		rows = <5>;
		/*
		 * Row 4 (thumb row) only has keys in columns 4 and 5.
		 * Remaining positions are marked RC(4,0)..RC(4,3) but
		 * will not be bound in the keymap.
		 */
		map = <
			RC(0,0) RC(0,1) RC(0,2) RC(0,3) RC(0,4) RC(0,5)
			RC(1,0) RC(1,1) RC(1,2) RC(1,3) RC(1,4) RC(1,5)
			RC(2,0) RC(2,1) RC(2,2) RC(2,3) RC(2,4) RC(2,5)
			RC(3,0) RC(3,1) RC(3,2) RC(3,3) RC(3,4) RC(3,5)
			                        RC(4,3) RC(4,4) RC(4,5)
		>;
	};

	encoder: encoder {
	    compatible = "alps,ec11";
		steps = <80>;
		status = "disabled";
	};

	sensors: sensors {
	    compatible = "zmk,keymap-sensors";
		sensors = <&encoder>;
		triggers-per-rotation = <20>;
	};

	kscan0: kscan {
		compatible = "zmk,kscan-gpio-matrix";
		wakeup-source;
		diode-direction = "col2row";
		/* row-gpios and col-gpios are defined in per-board DTS */
	};

	wired_split: wired_split {
	    compatible = "zmk,wired-split";
		device = <&uart0>;
	};
};

&pio0 {
    status = "okay";

    pio_ws2812: pio_ws2812 {
        compatible = "worldsemi,ws2812-rpi_pico-pio";
        pinctrl-0 = <&ws2812_pio_default>;
        pinctrl-names = "default";
        bit-waveform = <3>, <3>, <4>;

        led_strip: ws2812 {
            gpios = <&gpio0 13 GPIO_ACTIVE_HIGH>;  /* placeholder pin */
            chain-length = <26>;
            color-mapping =
                <LED_COLOR_ID_GREEN>,
                <LED_COLOR_ID_RED>,
                <LED_COLOR_ID_BLUE>;
            reset-delay = <280>;
            frequency = <800000>;
        };
    };
};
